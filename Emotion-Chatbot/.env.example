# ============================================================================
# Emotion-Aware AI Chatbot - Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env file to version control - it contains secrets!
# ============================================================================

# Groq API Configuration
# Get your API key from: https://console.groq.com/
GROQ_API_KEY=your-groq-api-key-here

# Database Configuration (Optional)
# Leave as default for SQLite local database
DATABASE_URL=sqlite:///emotion_chatbot.db

# CORS Configuration (Optional)
# Comma-separated list of allowed origins for frontend requests
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Debug Mode (Optional)
# Set to True for development, False for production
DEBUG=False

# Frontend API URL (Optional)
# Used for API calls from frontend
FRONTEND_API_URL=http://localhost:8000

# Emotion Model Configuration (Optional)
# Confidence threshold for emotion detection (0.0-1.0)
EMOTION_CONFIDENCE_THRESHOLD=0.6

# Groq LLM Configuration (Optional)
# Model to use for responses
GROQ_MODEL=mixtral-8x7b-32768

# Response Temperature (Optional)
# Controls randomness of responses (0.0-1.0)
# Lower = more deterministic, Higher = more creative
RESPONSE_TEMPERATURE=0.7

# Response Timeout (Optional)
# Timeout for LLM API calls in milliseconds
RESPONSE_TIMEOUT=15000
